{
  "name": "kumi-ui-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --sequential --filter '*' build",
    "dev": "bun run --parallel --filter '*' dev",
    "test": "bun run --parallel --filter '*' test",
    "typecheck": "bun run --sequential --filter '*' typecheck"
  }
}
